enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Event {
  id          String      @id @default(uuid())
  title       String
  description String
  category    String
  location    String
  startsAt    DateTime
  endsAt      DateTime
  price       Float       @default(0)
  rating      Float       @default(0)
  status      EventStatus @default(UPCOMING)
  mediaUrls   String[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([category])
  @@index([status])
  @@index([startsAt])
  @@index([location])
}
